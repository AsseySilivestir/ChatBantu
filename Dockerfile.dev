# ════════════════════════════════════════════════════════════════════
#  ChatBantu — Local Development Dockerfile (fast iteration)
#
#  Assumes PREBUILT bantu + wsrelay binaries in the repo root.
#  Includes nginx for full real-time (same as production).
#  Build time: ~10 seconds (vs ~3 minutes for production Dockerfile).
#
#  Run:  ./dev.sh --docker
#  Open: http://localhost:8080
# ════════════════════════════════════════════════════════════════════

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Africa/Dar_es_Salaam
ENV PORT=8080

# Runtime libs + nginx
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libsqlite3-0 \
        libcurl4 \
        ca-certificates \
        sqlite3 \
        curl \
        nginx \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy prebuilt binaries
COPY bantu   /usr/local/bin/bantu
COPY wsrelay /usr/local/bin/wsrelay
RUN chmod +x /usr/local/bin/bantu /usr/local/bin/wsrelay

# Copy app
COPY server.b /app/server.b
COPY public/  /app/public/

# Copy nginx config (same as production — /ws → wsrelay, /* → bantu)
COPY nginx.conf /etc/nginx/nginx.conf
RUN rm -f /etc/nginx/sites-enabled/default

# Copy entrypoint (starts wsrelay + bantu + nginx)
COPY docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh

RUN mkdir -p /data && chmod 777 /data

EXPOSE ${PORT}

CMD ["/app/docker-entrypoint.sh"]